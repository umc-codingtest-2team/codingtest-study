# 프로그래머스 - 같은 숫자는 싫어 (스택)
# 연속으로 같은 숫자가 나오면 하나만 남긴다.


def solution(arr):
    stack = []
    for x in arr:
        if not stack or stack[-1] != x:
            stack.append(x)
    return stack


if __name__ == "__main__":
    print(solution([1, 1, 3, 3, 0, 1, 1]))  # [1, 3, 0, 1]
    print(solution([4, 4, 4, 3, 3]))  # [4, 3]
